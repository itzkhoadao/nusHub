# Required
PORT=5000
DATABASE_URL=your_postgresql_connection_string
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_ISSUER=nushub-api
JWT_AUDIENCE=nushub-web
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Optional: Google Sign-In
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Optional: Cloudflare R2 attachment storage
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_BASE_URL=your_r2_public_base_url

# Planned: Gemini-powered NUS information assistant
# Keep disabled until the authenticated backend integration and release gates
# are implemented. Never expose these values through VITE_* variables.
AI_ENABLED=false
AI_PROVIDER=gemini
GEMINI_API_KEY=your_server_side_gemini_api_key
AI_GENERATION_MODEL=gemini-3.6-flash
AI_EMBEDDING_MODEL=gemini-embedding-001
AI_INTERACTIONS_STORE=false

# Planned: conservative application limits (validate at server startup)
AI_REQUEST_TIMEOUT_MS=20000
AI_MAX_INPUT_CHARS=2000
AI_MAX_OUTPUT_TOKENS=800
AI_MAX_TOOL_CALLS=3
AI_MAX_CONCURRENT_REQUESTS_PER_USER=1
AI_DAILY_REQUEST_LIMIT_PER_USER=50
